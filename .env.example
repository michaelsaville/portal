# -----------------------------------------------------------
# Portal — environment variables
#
# Copy to .env.local and fill in real values. Never commit secrets.
# -----------------------------------------------------------

# Postgres — same instance as DocHub + TicketHub. Portal isolates its
# tables inside the `portal` schema; multi-schema mode means db push
# won't touch DocHub/TicketHub tables.
DATABASE_URL="postgresql://dochub:REPLACE_ME@db:5432/dochub?schema=portal"

# Public base URL. Used in magic-link emails, password-reset links,
# OpenGraph metadata, etc.
PUBLIC_URL="https://portal.pcc2k.com"

# Session signing / encryption secret. 32+ random bytes, base64url.
# Rotate by appending to the list — old sessions keep verifying until
# they expire, new ones get signed with the first entry.
PORTAL_SESSION_SECRET="REPLACE_ME"

# BFF shared secret — HMAC over body+timestamp+nonce when calling
# DocHub / TicketHub back-for-frontend endpoints. Same value on both
# sides. See docs/API-CONTRACTS.md.
PORTAL_BFF_SECRET="REPLACE_ME"

# Admin allowlist — comma-separated PCC2K staff emails that can reach
# /admin/users. Temporary stopgap until there's a proper isStaff flag
# on PortalUser (see app/lib/portal-admin.ts).
PORTAL_ADMIN_EMAILS="michael@pcc2k.com"

# Entra AD (optional Phase 2). Leave blank until the app registration
# exists at portal.pcc2k.com/api/auth/callback/azure-ad.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Stripe (Phase 4 — invoice pay). Publishable + secret for one-time
# Checkout sessions, not subscriptions. Webhook secret for the
# payment_intent.succeeded handler.
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
